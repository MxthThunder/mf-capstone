table 06_industry_folio_count
	lineageTag: 5859d692-f2f7-4f77-8030-7a35ee94fd9f

	/// Latest total folios in Crore
	measure 'Latest Total Folios (Cr)' =
			VAR _lastMonth = MAXX(ALL('06_industry_folio_count'), '06_industry_folio_count'[month])
			RETURN CALCULATE(SUM('06_industry_folio_count'[total_folios_crore]), '06_industry_folio_count'[month] = _lastMonth)
		formatString: #,##0.00
		lineageTag: 01741269-defa-4357-a991-0ecb3696ff03

	column month
		dataType: dateTime
		formatString: Long Date
		lineageTag: b8bc9f47-285c-46ef-8d94-5303fa8260ff
		summarizeBy: none
		sourceColumn: month

		variation Variation
			isDefault
			relationship: b9f0529f-e177-44ae-95a5-94b0367e686b
			defaultHierarchy: LocalDateTable_83910e96-cd88-44a7-a8aa-915f9445cf55.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column total_folios_crore
		dataType: double
		lineageTag: 52122909-7f05-48d6-8c99-cf74fa514719
		summarizeBy: sum
		sourceColumn: total_folios_crore

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column equity_folios_crore
		dataType: double
		lineageTag: 9f2754d9-d90c-414b-b7bf-54dde98b3196
