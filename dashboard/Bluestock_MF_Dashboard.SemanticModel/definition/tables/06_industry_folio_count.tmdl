		sourceColumn: equity_folios_crore

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column debt_folios_crore
		dataType: double
		lineageTag: b696a08f-8b00-4cd4-98e5-2fdde434a232
		summarizeBy: none
		sourceColumn: debt_folios_crore

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column hybrid_folios_crore
		dataType: double
		lineageTag: da78c4d0-d046-47f7-94e1-f3706aa0e497
		summarizeBy: sum
		sourceColumn: hybrid_folios_crore

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column others_folios_crore
		dataType: double
		lineageTag: 0fc603ad-5a08-4a3f-86e9-d6d45802d84c
		summarizeBy: sum
		sourceColumn: others_folios_crore

