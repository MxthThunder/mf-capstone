		summarizeBy: none
		sourceColumn: fund_house

		annotation SummarizationSetBy = Automatic

	column aum_lakh_crore
		dataType: double
		lineageTag: 422c7a05-cecf-4cf2-aff2-56083d8e10f9
		summarizeBy: sum
		sourceColumn: aum_lakh_crore

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column aum_crore
		dataType: int64
		formatString: 0
		lineageTag: a2e6528e-d257-4add-83f4-273f2de2c073
		summarizeBy: none
		sourceColumn: aum_crore

		annotation SummarizationSetBy = Automatic

	column num_schemes
		dataType: int64
		formatString: 0
		lineageTag: 60b5bb37-fde1-4145-9bf6-00b6273b00a0
		summarizeBy: sum
		sourceColumn: num_schemes

		annotation SummarizationSetBy = Automatic

